{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public",
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "^/api/(.*)", "dest": "/dist/index.cjs" },
    { "handle": "filesystem" },
    { "src": "^/(.*)", "dest": "/dist/index.cjs" }
  ]
}
